---
// Events are grounded in real EPLAN Electric P8 API actions
// (export / label / backup / ExportProductionWiring) — the routing surface
// competitors don't map. "live" = supported first; "soon" = on the roadmap.
import { getLocaleFromUrl } from "../i18n/config";
import { useContent } from "../i18n/content";

const lang = getLocaleFromUrl(Astro.url);
const t = useContent(lang);
const events = t.events.items;
const destinations = t.events.destinations;
---

<section
  id="events"
  class="mx-auto max-w-6xl scroll-mt-20 border-x border-[var(--color-ink-12)] px-4 py-16 sm:px-6 sm:py-24"
>
  <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
    <div>
      <span class="eyebrow">{t.events.eyebrow}</span>
      <h2
        class="mt-4 text-3xl font-bold tracking-tight text-[var(--color-ink)] sm:text-4xl"
      >
        {t.events.heading}
      </h2>
      <p class="mt-3 max-w-md text-base leading-relaxed text-[var(--color-muted)]">
        {t.events.lead}
      </p>
      <ul class="mt-8 space-y-4">
        {
          events.map((event) => (
            <li class="panel p-5">
              <div class="flex flex-wrap items-center gap-3">
                <code class="rounded-sm border border-[var(--color-ink-12)] bg-[var(--color-panel)] px-2 py-1 font-mono text-xs text-[var(--color-accent-deep)]">
                  {event.id}
                </code>
                {event.soon ? (
                  <span class="rounded-sm border border-[var(--color-accent)] px-2 py-0.5 font-mono text-[10px] font-medium uppercase tracking-wider text-[var(--color-accent)]">
                    {t.events.soonLabel}
                  </span>
                ) : (
                  <span class="rounded-sm border border-[var(--color-ink-12)] px-2 py-0.5 font-mono text-[10px] font-medium uppercase tracking-wider text-[var(--color-muted)]">
                    {t.events.liveLabel}
                  </span>
                )}
              </div>
              <p class="mt-2 font-semibold text-[var(--color-ink)]">
                {event.title}
              </p>
              <p class="mt-1 text-base leading-relaxed text-[var(--color-muted)]">
                {event.body}
              </p>
              <p class="mt-2 font-mono text-[11px] tracking-wide text-[var(--color-ink-35)]">
                {event.action}
              </p>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <span class="eyebrow">{t.events.destEyebrow}</span>
      <h2
        class="mt-4 text-3xl font-bold tracking-tight text-[var(--color-ink)] sm:text-4xl"
      >
        {t.events.destHeading}
      </h2>
      <ul class="mt-8 grid gap-4 sm:grid-cols-2">
        {
          destinations.map((destination) => (
            <li class="panel p-5">
              <div class="flex items-center gap-2">
                <p class="font-semibold text-[var(--color-ink)]">
                  {destination.title}
                </p>
                {destination.soon && (
                  <span class="rounded-sm border border-[var(--color-accent)] px-1.5 py-0.5 font-mono text-[9px] font-medium uppercase tracking-wider text-[var(--color-accent)]">
                    {t.events.destSoonLabel}
                  </span>
                )}
              </div>
              <p class="mt-1 text-base leading-relaxed text-[var(--color-muted)]">
                {destination.body}
              </p>
            </li>
          ))
        }
      </ul>
      <p class="mt-6 font-mono text-xs leading-relaxed text-[var(--color-muted)]">
        {t.events.footnote}
      </p>
    </div>
  </div>
</section>
