---
import { getLocaleFromUrl } from "../i18n/config";
import { useContent } from "../i18n/content";

const lang = getLocaleFromUrl(Astro.url);
const t = useContent(lang);
const steps = t.how.steps.map((step, i) => ({
  n: String(i + 1).padStart(2, "0"),
  ...step,
}));
---

<section
  id="how-it-works"
  class="mx-auto max-w-6xl scroll-mt-20 border-x border-[var(--color-ink-12)] px-4 py-16 sm:px-6 sm:py-24"
>
  <div class="max-w-2xl">
    <span class="eyebrow">{t.how.eyebrow}</span>
    <h2
      class="mt-4 text-3xl font-bold tracking-tight text-[var(--color-ink)] sm:text-4xl"
    >
      {t.how.heading}
    </h2>
  </div>

  <ol class="mt-10 grid gap-px overflow-hidden border border-[var(--color-ink-12)] md:grid-cols-3">
    {
      steps.map((step) => (
        <li class="flex flex-col bg-[var(--color-paper)] p-6 outline outline-1 outline-[var(--color-ink-12)] sm:p-8">
          <span class="font-mono text-sm font-semibold text-[var(--color-accent)]">
            {step.n}
          </span>
          <h3 class="mt-4 text-lg font-semibold text-[var(--color-ink)]">
            {step.title}
          </h3>
          <p class="mt-2 text-base leading-relaxed text-[var(--color-muted)]">
            {step.body}
          </p>
        </li>
      ))
    }
  </ol>
</section>
