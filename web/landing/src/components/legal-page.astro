---
import { getLocaleFromUrl, localizePath } from "../i18n/config";
import { useContent } from "../i18n/content";
import type { LegalDoc } from "../i18n/types";

interface Props {
  doc: LegalDoc;
}

const lang = getLocaleFromUrl(Astro.url);
const t = useContent(lang);
const { eyebrow, title, intro, sections } = Astro.props.doc;
const updated = t.legal.updated;
const home = localizePath("/", lang);
---

<main
  class="mx-auto max-w-3xl border-x border-[var(--color-ink-12)] px-4 py-16 sm:px-6 sm:py-24"
>
  <a
    href={home}
    class="eyebrow mb-8 no-underline"
    style="text-decoration: none;"
  >
    <span class="arrow" aria-hidden="true">&#8592;</span>&nbsp;{t.legal.back}
  </a>

  <p class="eyebrow">{eyebrow}</p>
  <h1
    class="mt-4 text-4xl font-bold tracking-tight text-[var(--color-ink)] sm:text-5xl"
  >
    {title}
  </h1>
  <p class="mt-3 font-mono text-xs tracking-wide text-[var(--color-muted)]">
    {t.legal.lastUpdatedLabel} · {updated} · {t.legal.draftLabel}
  </p>

  <p class="mt-8 text-lg leading-relaxed text-[var(--color-muted)]">{intro}</p>

  <div class="mt-10 space-y-8">
    {
      sections.map((section, i) => (
        <section class="border-t border-[var(--color-ink-12)] pt-8">
          <h2 class="flex items-baseline gap-3 text-xl font-semibold text-[var(--color-ink)]">
            <span class="font-mono text-sm text-[var(--color-accent)]">
              {String(i + 1).padStart(2, "0")}
            </span>
            {section.heading}
          </h2>
          {section.body.map((p) => (
            <p class="mt-3 text-base leading-relaxed text-[var(--color-muted)]">
              {p}
            </p>
          ))}
        </section>
      ))
    }
  </div>

  <p
    class="mt-12 border-t border-[var(--color-ink-12)] pt-6 font-mono text-xs leading-relaxed text-[var(--color-ink-35)]"
  >
    {t.legal.disclaimer}{" "}<a
      href="mailto:hello@covaga.dev"
      class="text-[var(--color-accent-deep)]">hello@covaga.dev</a
    >.
  </p>
</main>
