---
interface Section {
  heading: string;
  body: string[];
}

interface Props {
  eyebrow: string;
  title: string;
  updated: string;
  intro: string;
  sections: Section[];
}

const { eyebrow, title, updated, intro, sections } = Astro.props;
---

<main
  class="mx-auto max-w-3xl border-x border-[var(--color-ink-12)] px-4 py-16 sm:px-6 sm:py-24"
>
  <a href="/" class="eyebrow mb-8 no-underline" style="text-decoration: none;">
    <span class="arrow" aria-hidden="true">&#8592;</span>&nbsp;back to byndr
  </a>

  <p class="eyebrow">{eyebrow}</p>
  <h1
    class="mt-4 text-4xl font-bold tracking-tight text-[var(--color-ink)] sm:text-5xl"
  >
    {title}
  </h1>
  <p class="mt-3 font-mono text-xs tracking-wide text-[var(--color-muted)]">
    last updated · {updated} · placeholder draft
  </p>

  <div
    class="mt-8 border border-[var(--color-accent)] bg-[rgba(91,138,255,0.06)] px-4 py-3 font-mono text-xs leading-relaxed text-[var(--color-ink-70)]"
    role="note"
  >
    PLACEHOLDER — this document is an early, non-binding draft for an
    early-access product. It is not legal advice and does not yet constitute a
    contract.
  </div>

  <p class="mt-8 text-lg leading-relaxed text-[var(--color-muted)]">{intro}</p>

  <div class="mt-10 space-y-8">
    {
      sections.map((section, i) => (
        <section class="border-t border-[var(--color-ink-12)] pt-8">
          <h2 class="flex items-baseline gap-3 text-xl font-semibold text-[var(--color-ink)]">
            <span class="font-mono text-sm text-[var(--color-accent)]">
              {String(i + 1).padStart(2, "0")}
            </span>
            {section.heading}
          </h2>
          {section.body.map((p) => (
            <p class="mt-3 text-base leading-relaxed text-[var(--color-muted)]">
              {p}
            </p>
          ))}
        </section>
      ))
    }
  </div>

  <p
    class="mt-12 border-t border-[var(--color-ink-12)] pt-6 font-mono text-xs leading-relaxed text-[var(--color-ink-35)]"
  >
    This document is a placeholder draft and does not yet constitute legal
    advice. Questions? <a
      href="mailto:hello@covaga.xyz"
      class="text-[var(--color-accent-deep)]">hello@covaga.xyz</a
    >.
  </p>
</main>
