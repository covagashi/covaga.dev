---
const pillars = [
  {
    tag: "pillar 01 · data + gym",
    title: "Close the gaps in your article data.",
    body: "Ingest a read-only snapshot of your EPLAN article database. An LLM closes text gaps — translations, descriptions — against deterministic validators. Every change is reviewed like a pull request; a local client writes approved values back into EPLAN.",
    points: [
      "the model proposes, the validator decides",
      "overlay only — ingested data is never mutated",
      "approved changes flow back through a local client",
    ],
    href: "#gym",
    cta: "how the gym works",
  },
  {
    tag: "pillar 02 · automations",
    title: "Route EPLAN events where the team looks.",
    body: "A PDF export, a BOM change, a project event — captured next to EPLAN and routed to the destinations your engineering team already watches: Microsoft Teams, email, a shared drive, or a plain webhook you control.",
    points: [
      "configured routes, not one-off macros",
      "credentials stay server-side",
      "a generic webhook forwards anywhere else",
    ],
    href: "#events",
    cta: "events & destinations",
  },
];
---

<section
  id="pillars"
  class="mx-auto max-w-6xl scroll-mt-20 border-x border-[var(--color-ink-12)] px-4 py-16 sm:px-6 sm:py-24"
>
  <div class="max-w-2xl">
    <span class="eyebrow">the platform</span>
    <h2
      class="mt-4 text-3xl font-bold tracking-tight text-[var(--color-ink)] sm:text-4xl"
    >
      Two pillars, one database.
    </h2>
    <p class="mt-3 max-w-md text-base leading-relaxed text-[var(--color-muted)]">
      byndr is a unified EPLAN platform. Both pillars share one tenant, one auth
      model, and the same hard boundary: the cloud never writes to EPLAN
      directly.
    </p>
  </div>

  <div class="mt-10 grid gap-6 lg:grid-cols-2">
    {
      pillars.map((pillar) => (
        <article class="panel flex flex-col p-6 sm:p-8">
          <h3 class="font-mono text-xs font-medium uppercase tracking-wider text-[var(--color-accent)]">
            {pillar.tag}
          </h3>
          <p class="mt-4 text-xl font-semibold text-[var(--color-ink)]">
            {pillar.title}
          </p>
          <p class="mt-3 text-base leading-relaxed text-[var(--color-muted)]">
            {pillar.body}
          </p>
          <ul class="mt-6 space-y-3 text-base text-[var(--color-muted)]">
            {pillar.points.map((point) => (
              <li class="flex items-start gap-2">
                <span
                  aria-hidden="true"
                  class="mt-1.5 inline-block h-1.5 w-1.5 flex-none bg-[var(--color-accent)]"
                />
                <span>{point}</span>
              </li>
            ))}
          </ul>
          <a
            href={pillar.href}
            class="mt-8 inline-flex w-fit items-center gap-2 font-mono text-sm font-medium text-[var(--color-accent-deep)] transition-colors hover:text-[var(--color-ink)]"
          >
            {pillar.cta}
            <span aria-hidden="true">&#8594;</span>
          </a>
        </article>
      ))
    }
  </div>
</section>
