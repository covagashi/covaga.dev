---
import { getLocaleFromUrl, localizePath } from "../i18n/config";
import { useContent } from "../i18n/content";

const lang = getLocaleFromUrl(Astro.url);
const t = useContent(lang);
const { period } = t.pricing;
const tiers = t.pricing.tiers;
const signupHref = localizePath("/signup", lang);
---

<section
  id="pricing"
  class="mx-auto max-w-6xl scroll-mt-20 border-x border-[var(--color-ink-12)] px-4 py-16 sm:px-6 sm:py-24"
>
  <div class="max-w-2xl">
    <span class="eyebrow">{t.pricing.eyebrow}</span>
    <h2
      class="mt-4 text-3xl font-bold tracking-tight text-[var(--color-ink)] sm:text-4xl"
    >
      {t.pricing.heading}
    </h2>
    <p class="mt-3 text-base text-[var(--color-muted)]">
      {t.pricing.lead}
    </p>
  </div>

  <div class="mt-10 grid gap-6 lg:grid-cols-3">
    {
      tiers.map((tier) => (
        <article
          class={`relative flex flex-col p-6 sm:p-8 ${
            tier.popular ? "panel-hub" : "panel"
          }`}
        >
          {tier.popular && (
            <span class="absolute -top-3 left-6 rounded-sm border border-[var(--color-accent)] bg-[var(--color-accent)] px-3 py-1 font-mono text-[11px] font-medium uppercase tracking-wider text-[var(--color-ink)]">
              {t.pricing.mostPopular}
            </span>
          )}
          <h3 class="text-lg font-semibold text-[var(--color-ink)]">
            {tier.name}
          </h3>
          <p class="mt-1 text-base text-[var(--color-muted)]">{tier.tagline}</p>
          <p class="mt-5 flex items-baseline gap-1">
            <span class="text-4xl font-bold tracking-tight text-[var(--color-ink)]">
              {tier.price}
            </span>
            <span class="text-base text-[var(--color-muted)]">
              {period}
            </span>
          </p>
          <ul class="mt-6 space-y-3 text-base text-[var(--color-muted)]">
            {tier.features.map((feature) => (
              <li class="flex items-start gap-2">
                <span
                  aria-hidden="true"
                  class="mt-1.5 inline-block h-1.5 w-1.5 flex-none bg-[var(--color-accent)]"
                />
                <span>{feature}</span>
              </li>
            ))}
          </ul>
          <a
            href={signupHref}
            class={`mt-8 ${tier.popular ? "btn-solid" : "btn-ghost"}`}
          >
            {tier.cta}
          </a>
        </article>
      ))
    }
  </div>
</section>
