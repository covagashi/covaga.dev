---
import { getLocaleFromUrl } from "../i18n/config";
import { useContent } from "../i18n/content";

const lang = getLocaleFromUrl(Astro.url);
const t = useContent(lang);
const { today, solution } = t.problem;
---

<section
  class="mx-auto max-w-6xl border-x border-[var(--color-ink-12)] px-4 py-16 sm:px-6 sm:py-24"
>
  <div class="max-w-2xl">
    <span class="eyebrow">{t.problem.eyebrow}</span>
    <h2
      class="mt-4 text-3xl font-bold tracking-tight text-[var(--color-ink)] sm:text-4xl"
    >
      {t.problem.heading}
    </h2>
  </div>

  <div class="mt-10 grid gap-6 lg:grid-cols-2">
    <article class="panel p-6 sm:p-8">
      <h3
        class="font-mono text-xs font-medium uppercase tracking-wider text-[var(--color-muted)]"
      >
        {t.problem.todayLabel}
      </h3>
      <ul class="mt-5 space-y-5">
        {
          today.map((item) => (
            <li class="border-l border-[var(--color-ink-12)] pl-4">
              <p class="font-semibold text-[var(--color-ink)]">{item.title}</p>
              <p class="mt-1 text-base leading-relaxed text-[var(--color-muted)]">
                {item.body}
              </p>
            </li>
          ))
        }
      </ul>
    </article>

    <article class="panel-hub p-6 sm:p-8">
      <h3
        class="font-mono text-xs font-medium uppercase tracking-wider text-[var(--color-accent)]"
      >
        {t.problem.withLabel}
      </h3>
      <ul class="mt-5 space-y-5">
        {
          solution.map((item) => (
            <li class="border-l border-[var(--color-accent)] pl-4">
              <p class="font-semibold text-[var(--color-ink)]">{item.title}</p>
              <p class="mt-1 text-base leading-relaxed text-[var(--color-muted)]">
                {item.body}
              </p>
            </li>
          ))
        }
      </ul>
    </article>
  </div>
</section>
