---
// Pre-launch waitlist: Covaga Hub self-service signup is not open yet, so this
// surface only collects an email. It posts to the worker's POST /api/waitlist
// (idempotent) and shows a thank-you on success. When signup opens, restore the
// tenant-creation form from git history (it used POST /api/signup).
import { getLocaleFromUrl } from "../i18n/config";
import { useContent } from "../i18n/content";

const lang = getLocaleFromUrl(Astro.url);
const t = useContent(lang);
const s = t.signup;

const API_BASE =
  import.meta.env.PUBLIC_API_URL ?? "https://covaga-hub.clopez-5fd.workers.dev";
---

<section
  class="mx-auto max-w-6xl border-x border-[var(--color-ink-12)] px-4 py-16 sm:px-6 sm:py-24"
>
  <div class="max-w-2xl">
    <span class="eyebrow">{s.eyebrow}</span>
    <h1
      class="mt-4 text-3xl font-bold tracking-tight text-[var(--color-ink)] sm:text-4xl"
    >
      {s.heading}
    </h1>
    <p class="mt-3 text-base text-[var(--color-muted)]">{s.lead}</p>
  </div>

  <div id="signup-form-wrap" class="mt-10 max-w-2xl">
    <form id="signup-form" class="panel p-6 sm:p-8" novalidate>
      <div class="grid gap-5">
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-[var(--color-ink)]"
            >{s.emailLabel}</span
          >
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            class="w-full border border-[var(--color-ink-35)] bg-white px-3 py-2.5 font-mono text-sm text-[var(--color-ink)] focus:border-[var(--color-accent)] focus:outline-none"
          />
        </label>

        <!-- Honeypot: humans never see or fill this. -->
        <input
          type="text"
          name="website"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
          class="absolute -left-[9999px] h-0 w-0 opacity-0"
        />

        <p
          id="signup-error"
          class="hidden border border-[var(--color-accent)] px-4 py-3 font-mono text-sm text-[var(--color-accent-deep,#d6520f)]"
          role="alert"
        >
        </p>

        <button type="submit" id="signup-submit" class="btn-solid w-full sm:w-auto">
          {s.submit}
        </button>
      </div>
    </form>
  </div>

  <div id="signup-success" class="mt-10 hidden">
    <div class="panel-hub p-6 sm:p-8">
      <h2 class="text-2xl font-bold tracking-tight text-[var(--color-ink)]">
        {s.successHeading}
      </h2>
      <p class="mt-2 max-w-2xl text-base text-[var(--color-muted)]">
        {s.successLead}
      </p>
    </div>
  </div>
</section>

<script
  define:vars={{
    API_BASE,
    locale: lang,
    submitLabel: s.submit,
    submittingLabel: s.submitting,
    errorGeneric: s.errorGeneric,
  }}
>
  const form = document.getElementById("signup-form");
  const errorBox = document.getElementById("signup-error");
  const submitBtn = document.getElementById("signup-submit");
  const formWrap = document.getElementById("signup-form-wrap");
  const successBox = document.getElementById("signup-success");

  function showSuccess() {
    formWrap.classList.add("hidden");
    successBox.classList.remove("hidden");
    successBox.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  form.addEventListener("submit", async (event) => {
    event.preventDefault();
    errorBox.classList.add("hidden");

    const data = new FormData(form);
    // Honeypot: a filled hidden field means a bot — pretend success, post nothing.
    if (String(data.get("website") ?? "")) {
      showSuccess();
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = submittingLabel;

    const payload = {
      email: String(data.get("email") ?? "").trim(),
      locale,
    };

    try {
      const response = await fetch(`${API_BASE}/api/waitlist`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      const json = await response.json().catch(() => ({}));

      if (!response.ok || !json.ok) {
        errorBox.textContent = errorGeneric;
        errorBox.classList.remove("hidden");
        return;
      }

      showSuccess();
    } catch {
      errorBox.textContent = errorGeneric;
      errorBox.classList.remove("hidden");
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = submitLabel;
    }
  });
</script>
