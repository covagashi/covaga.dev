---
// Self-service tenant signup: email (+ optional company) only. Connections
// (Telegram, Drive, webhooks) and event routing are configured afterwards in
// the dashboard. Posts to the worker's POST /signup, which returns
// tenantId + apiKey exactly once.
import { getLocaleFromUrl } from "../i18n/config";
import { useContent } from "../i18n/content";

const lang = getLocaleFromUrl(Astro.url);
const t = useContent(lang);
const s = t.signup;

const API_BASE =
  import.meta.env.PUBLIC_API_URL ?? "https://eplanbridge-api.clopez-5fd.workers.dev";
---

<section
  class="mx-auto max-w-6xl border-x border-[var(--color-ink-12)] px-4 py-16 sm:px-6 sm:py-24"
>
  <div class="max-w-2xl">
    <span class="eyebrow">{s.eyebrow}</span>
    <h1
      class="mt-4 text-3xl font-bold tracking-tight text-[var(--color-ink)] sm:text-4xl"
    >
      {s.heading}
    </h1>
    <p class="mt-3 text-base text-[var(--color-muted)]">{s.lead}</p>
  </div>

  <div class="mt-10 max-w-2xl">
    <form id="signup-form" class="panel p-6 sm:p-8" novalidate>
      <div class="grid gap-5">
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-[var(--color-ink)]"
            >{s.emailLabel}</span
          >
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            class="w-full border border-[var(--color-ink-35)] bg-white px-3 py-2.5 font-mono text-sm text-[var(--color-ink)] focus:border-[var(--color-accent)] focus:outline-none"
          />
        </label>

        <label class="block">
          <span class="mb-1 block text-sm font-medium text-[var(--color-ink)]"
            >{s.companyLabel}</span
          >
          <input
            type="text"
            name="company"
            maxlength="200"
            autocomplete="organization"
            class="w-full border border-[var(--color-ink-35)] bg-white px-3 py-2.5 font-mono text-sm text-[var(--color-ink)] focus:border-[var(--color-accent)] focus:outline-none"
          />
        </label>

        <!-- Honeypot: humans never see or fill this. -->
        <input
          type="text"
          name="website"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
          class="absolute -left-[9999px] h-0 w-0 opacity-0"
        />

        <p
          id="signup-error"
          class="hidden border border-[var(--color-accent)] px-4 py-3 font-mono text-sm text-[var(--color-accent-deep,#d6520f)]"
          role="alert"
        >
        </p>

        <button type="submit" id="signup-submit" class="btn-solid w-full sm:w-auto">
          {s.submit}
        </button>
      </div>
    </form>
  </div>

  <div id="signup-success" class="mt-10 hidden">
    <div class="panel-hub p-6 sm:p-8">
      <h2 class="text-2xl font-bold tracking-tight text-[var(--color-ink)]">
        {s.successHeading}
      </h2>
      <p class="mt-2 max-w-2xl text-base text-[var(--color-muted)]">{s.successLead}</p>

      <dl class="mt-6 grid gap-4">
        <div>
          <dt class="font-mono text-[11px] uppercase tracking-wider text-[var(--color-muted)]">
            {s.tenantIdLabel}
          </dt>
          <dd class="mt-1 flex flex-wrap items-center gap-2">
            <code
              id="out-tenant"
              class="border border-[var(--color-ink-12)] bg-white px-3 py-2 font-mono text-sm"
            ></code>
            <button type="button" class="btn-ghost copy-btn text-xs" data-copy="out-tenant">
              {s.copy}
            </button>
          </dd>
        </div>
        <div>
          <dt class="font-mono text-[11px] uppercase tracking-wider text-[var(--color-muted)]">
            {s.apiKeyLabel}
          </dt>
          <dd class="mt-1 flex flex-wrap items-center gap-2">
            <code
              id="out-key"
              class="border border-[var(--color-accent)] bg-white px-3 py-2 font-mono text-sm"
            ></code>
            <button type="button" class="btn-ghost copy-btn text-xs" data-copy="out-key">
              {s.copy}
            </button>
          </dd>
        </div>
      </dl>

      <h3 class="mt-8 text-lg font-semibold text-[var(--color-ink)]">{s.nextHeading}</h3>
      <ol class="mt-3 list-decimal space-y-2 pl-5 text-base text-[var(--color-muted)]">
        {s.nextSteps.map((step) => <li>{step}</li>)}
      </ol>
    </div>
  </div>
</section>

<script
  define:vars={{
    API_BASE,
    submitLabel: s.submit,
    submittingLabel: s.submitting,
    errorGeneric: s.errorGeneric,
  }}
>
  const form = document.getElementById("signup-form");
  const errorBox = document.getElementById("signup-error");
  const submitBtn = document.getElementById("signup-submit");
  const successBox = document.getElementById("signup-success");

  form.addEventListener("submit", async (event) => {
    event.preventDefault();
    errorBox.classList.add("hidden");
    submitBtn.disabled = true;
    submitBtn.textContent = submittingLabel;

    const data = new FormData(form);
    const payload = {
      email: String(data.get("email") ?? "").trim(),
      website: String(data.get("website") ?? ""),
    };
    const company = String(data.get("company") ?? "").trim();
    if (company) payload.company = company;

    try {
      const response = await fetch(`${API_BASE}/signup`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      const json = await response.json().catch(() => ({}));

      if (!response.ok || !json.ok) {
        errorBox.textContent = errorGeneric;
        errorBox.classList.remove("hidden");
        return;
      }

      document.getElementById("out-tenant").textContent = json.tenantId;
      document.getElementById("out-key").textContent = json.apiKey;
      form.closest("div").classList.add("hidden");
      successBox.classList.remove("hidden");
      successBox.scrollIntoView({ behavior: "smooth", block: "start" });
    } catch {
      errorBox.textContent = errorGeneric;
      errorBox.classList.remove("hidden");
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = submitLabel;
    }
  });

  for (const btn of document.querySelectorAll(".copy-btn")) {
    btn.addEventListener("click", () => {
      const target = document.getElementById(btn.dataset.copy);
      if (target?.textContent) navigator.clipboard?.writeText(target.textContent);
    });
  }
</script>
