---
import { getLocaleFromUrl, localizePath } from "../i18n/config";
import { useContent } from "../i18n/content";

const lang = getLocaleFromUrl(Astro.url);
const t = useContent(lang);
const c = t.umbrella.cta;
const signup = localizePath("/signup", lang);
---

<section class="border-t border-[var(--color-ink-12)]">
  <div
    class="mx-auto max-w-6xl border-x border-[var(--color-ink-12)] px-4 py-16 sm:px-6 sm:py-20"
  >
    <p class="eyebrow">{c.eyebrow}</p>
    <h2
      class="mt-4 max-w-xl text-3xl font-bold leading-tight tracking-tight text-balance text-[var(--color-ink)] sm:text-4xl"
    >
      {c.heading}
    </h2>
    <div class="mt-7 flex flex-wrap gap-3">
      <a href={signup} class="btn-solid">{c.primary}</a>
      <a href="https://github.com/covagashi" class="btn-ghost">{c.secondary}</a>
    </div>
  </div>
</section>
