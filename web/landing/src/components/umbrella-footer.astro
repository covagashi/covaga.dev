---
import { locales, localeShort, getLocaleFromUrl, localizePath } from "../i18n/config";
import { useContent } from "../i18n/content";

const lang = getLocaleFromUrl(Astro.url);
const t = useContent(lang);
const f = t.umbrella.footer;
const home = localizePath("/", lang);
const hub = localizePath("/hub", lang);
const year = new Date().getFullYear();

const toolLinks = [
  { href: home + "#eplan-rag-mcp", label: "eplan-rag-mcp" },
  { href: home + "#ecad-view", label: "ecad-view" },
  { href: hub, label: "covaga hub" },
];
const codeLinks = [
  { href: "https://github.com/covagashi/covaga.dev", label: "covaga.dev" },
  { href: "https://github.com/covagashi/eplan-rag-mcp", label: "eplan-rag-mcp" },
  { href: "https://github.com/covagashi/ecad-view", label: "ecad-view" },
];
const projectLinks = [
  { href: "https://covaga.xyz", label: "covaga.xyz", ext: true },
  { href: "mailto:hello@covaga.dev", label: "hello@covaga.dev", ext: false },
  { href: localizePath("/privacy", lang), label: t.footer.privacy, ext: false },
  { href: localizePath("/terms", lang), label: t.footer.terms, ext: false },
];

const titleblock = [
  { k: "drawing", v: "covaga.dev" },
  { k: "sheet", v: "1 / 1" },
  { k: "rev", v: "A · draft" },
  { k: "scale", v: "1:1" },
];
---

<footer class="border-t border-[var(--color-ink)]">
  <div
    class="mx-auto max-w-6xl border-x border-[var(--color-ink-12)] px-4 py-12 sm:px-6"
  >
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-[1.6fr_1fr_1fr_1fr]">
      <!-- brand -->
      <div class="max-w-sm">
        <a href={home + "#top"} class="flex items-baseline gap-2">
          <span class="text-lg font-bold tracking-tight text-[var(--color-ink)]"
            >covaga<span class="text-[var(--color-accent)]">.</span></span
          >
          <span class="font-mono text-[11px] tracking-wide text-[var(--color-muted)]"
            >// eplan toolkit</span
          >
        </a>
        <p class="mt-3 text-sm leading-relaxed text-[var(--color-muted)]">
          {f.tagline}
        </p>
        <a
          href="https://covaga.xyz"
          class="mt-5 inline-flex items-center gap-2 rounded-sm border border-[var(--color-ink-12)] px-3 py-2 font-mono text-[12px] tracking-wide text-[var(--color-ink-70)] transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
        >
          <span class="h-[7px] w-[7px] flex-none rounded-full bg-[var(--color-accent)]"
          ></span>
          {f.net} &#8599;
        </a>
      </div>

      <!-- tools -->
      <nav aria-label={f.toolsLabel}>
        <p
          class="font-mono text-[11px] uppercase tracking-wider text-[var(--color-ink-35)]"
        >
          {f.toolsLabel}
        </p>
        <ul class="mt-4 flex flex-col gap-2.5 text-sm">
          {
            toolLinks.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="text-[var(--color-ink-70)] transition-colors hover:text-[var(--color-accent)]"
                >
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- code -->
      <nav aria-label={f.codeLabel}>
        <p
          class="font-mono text-[11px] uppercase tracking-wider text-[var(--color-ink-35)]"
        >
          {f.codeLabel}
        </p>
        <ul class="mt-4 flex flex-col gap-2.5 text-sm">
          {
            codeLinks.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="inline-flex items-center gap-1 text-[var(--color-ink-70)] transition-colors hover:text-[var(--color-accent)]"
                >
                  {l.label}{" "}
                  <span class="font-mono text-[0.72em] text-[var(--color-ink-35)]">
                    &#8599;
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- project -->
      <nav aria-label={f.projectLabel}>
        <p
          class="font-mono text-[11px] uppercase tracking-wider text-[var(--color-ink-35)]"
        >
          {f.projectLabel}
        </p>
        <ul class="mt-4 flex flex-col gap-2.5 text-sm">
          {
            projectLinks.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="inline-flex items-center gap-1 text-[var(--color-ink-70)] transition-colors hover:text-[var(--color-accent)]"
                >
                  {l.label}
                  {l.ext && (
                    <span class="font-mono text-[0.72em] text-[var(--color-ink-35)]">
                      &#8599;
                    </span>
                  )}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <!-- drafting title block -->
    <div
      class="mt-11 grid grid-cols-2 overflow-hidden rounded-sm border border-[var(--color-ink-35)] font-mono text-[11px] text-[var(--color-ink-55)] sm:grid-cols-4"
    >
      {
        titleblock.map((cell) => (
          <div class="border-b border-r border-[var(--color-ink-12)] px-3 py-2.5 last:border-r-0 sm:border-b-0">
            {cell.k}
            <b class="mt-0.5 block font-medium tracking-wide text-[var(--color-ink)]">
              {cell.v}
            </b>
          </div>
        ))
      }
    </div>

    <div class="mt-7 flex flex-wrap items-baseline justify-between gap-4">
      <div class="flex flex-wrap gap-1.5" aria-label={f.localesLabel}>
        {
          locales.map((loc) => (
            <span
              class:list={[
                "rounded-sm border px-1.5 py-0.5 font-mono text-[11px] tracking-wide",
                loc === lang
                  ? "border-[var(--color-accent)] text-[var(--color-accent)]"
                  : "border-[var(--color-ink-12)] text-[var(--color-ink-55)]",
              ]}
            >
              {localeShort[loc].toLowerCase()}
            </span>
          ))
        }
      </div>
      <span class="font-mono text-[12px] text-[var(--color-ink-55)]"
        >&copy; {year} covaga</span
      >
    </div>

    <p class="mt-6 max-w-3xl text-[13px] leading-relaxed text-[var(--color-ink-55)]">
      {t.footer.disclaimer}
    </p>
  </div>
</footer>
