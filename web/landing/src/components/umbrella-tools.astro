---
import { getLocaleFromUrl } from "../i18n/config";
import { useContent } from "../i18n/content";

const lang = getLocaleFromUrl(Astro.url);
const t = useContent(lang);
const s = t.umbrella.tools;

/** Stable anchor id from a tool name, e.g. "eplan-rag-mcp", "covaga-hub". */
function toId(name: string): string {
  return name.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
}
---

<section id="tools" class="border-t border-[var(--color-ink-12)]">
  <div
    class="mx-auto max-w-6xl border-x border-[var(--color-ink-12)] px-4 py-16 sm:px-6 sm:py-20"
  >
    <div class="max-w-2xl">
      <p class="eyebrow">{s.eyebrow}</p>
      <h2
        class="mt-5 text-3xl font-bold leading-tight tracking-tight text-balance text-[var(--color-ink)] sm:text-4xl"
      >
        {s.heading}
      </h2>
      <p class="mt-4 max-w-xl text-lg leading-relaxed text-[var(--color-muted)]">
        {s.lead}
      </p>
    </div>

    <div class="mt-11 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {
        s.items.map((tool) => (
          <article
            id={toId(tool.name)}
            class:list={[
              "term-box relative flex flex-col p-6",
              tool.primary && "border-[var(--color-accent)]",
            ]}
          >
            <span class="absolute left-6 top-0 h-[3px] w-6 bg-[var(--color-accent)]" />
            <span class="font-mono text-[11px] tracking-wide text-[var(--color-ink-55)]">
              {tool.ref}
            </span>
            <h3 class="mt-3 font-mono text-[1.05rem] font-medium tracking-tight text-[var(--color-ink)]">
              {tool.name}
            </h3>
            <p class="mt-1 text-[1.02rem] font-semibold leading-snug text-[var(--color-ink)]">
              {tool.what}
            </p>
            <p class="mt-3 text-[0.92rem] leading-relaxed text-[var(--color-muted)]">
              {tool.body}
            </p>

            <div class="mt-4 flex flex-wrap gap-1.5">
              {tool.chips.map((c) => (
                <span class="chip">
                  {c.label} <b>{c.value}</b>
                </span>
              ))}
            </div>

            <div class="mt-auto flex items-center justify-between gap-3 border-t border-dashed border-[var(--color-ink-12)] pt-4">
              <span class="flex items-center gap-1.5 font-mono text-[11px] tracking-wide text-[var(--color-ink-70)]">
                <span
                  class:list={[
                    "h-[7px] w-[7px] flex-none rounded-full",
                    tool.statusKind === "hosted"
                      ? "bg-[var(--color-accent)]"
                      : "bg-[var(--color-ink-55)]",
                  ]}
                />
                {tool.status}
              </span>
              <span class="flex flex-wrap justify-end gap-x-3.5 gap-y-1">
                {tool.links.map((l) => (
                  <a
                    href={l.href}
                    class="border-b border-[var(--color-ink-12)] pb-px font-mono text-[12px] tracking-wide text-[var(--color-ink-70)] transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
                  >
                    {l.label}
                  </a>
                ))}
              </span>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
