---
import "../styles/global.css";
import {
  locales,
  localeHtmlLang,
  getLocaleFromUrl,
  localizePath,
  stripLocale,
  defaultLocale,
} from "../i18n/config";
import { useContent } from "../i18n/content";
import LanguageBanner from "../components/language-banner.astro";

interface Props {
  title?: string;
  description?: string;
}

const lang = getLocaleFromUrl(Astro.url);
const t = useContent(lang);

const { title = t.meta.homeTitle, description = t.meta.homeDescription } =
  Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/og.png", Astro.site);

// hreflang alternates: same page, every locale.
const route = stripLocale(Astro.url.pathname);
const alternates = locales.map((locale) => ({
  hreflang: localeHtmlLang[locale],
  href: new URL(localizePath(route, locale), Astro.site).href,
}));
const xDefault = new URL(localizePath(route, defaultLocale), Astro.site).href;
---

<!doctype html>
<html lang={localeHtmlLang[lang]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonicalURL} />
    {
      alternates.map((alt) => (
        <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={xDefault} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
  </head>
  <body>
    <a
      href="#top"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-sm focus:bg-[var(--color-accent)] focus:px-4 focus:py-2 focus:font-medium focus:text-[var(--color-ink)]"
    >
      {t.a11y.skipToContent}
    </a>

    <div class="grid-overlay" aria-hidden="true"></div>

    <div class="site-shell">
      <slot />
    </div>

    <LanguageBanner />

    <script>
      // Spotlight-reveal grid: follow the pointer, "develop" the drafting grid.
      (function () {
        const overlay = document.querySelector<HTMLElement>(".grid-overlay");
        if (!overlay) return;

        const media = window.matchMedia("(pointer: fine)");
        if (!media.matches) return; // touch devices: keep it clean, no reveal

        let raf: number | null = null;
        let x = -400;
        let y = -400;

        function paint() {
          overlay!.style.setProperty("--mx", x + "px");
          overlay!.style.setProperty("--my", y + "px");
          raf = null;
        }

        window.addEventListener(
          "pointermove",
          (event) => {
            x = event.clientX;
            y = event.clientY;
            if (!overlay!.classList.contains("is-live")) {
              overlay!.classList.add("is-live");
            }
            if (raf === null) raf = requestAnimationFrame(paint);
          },
          { passive: true },
        );

        document.addEventListener("pointerleave", () => {
          overlay!.classList.remove("is-live");
        });
      })();
    </script>
  </body>
</html>
