---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "byndr — one platform for your EPLAN data and events",
  description =
    "byndr ingests your EPLAN article database and closes text gaps with a reviewed, validated loop — and routes EPLAN events to Microsoft Teams, email or a webhook. The cloud never writes to EPLAN directly.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/og.svg", Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0b0c0f" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
  </head>
  <body>
    <a
      href="#top"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-sm focus:bg-[var(--color-accent)] focus:px-4 focus:py-2 focus:font-medium focus:text-[#07080b]"
    >
      Skip to content
    </a>

    <div class="grid-overlay" aria-hidden="true"></div>

    <div class="site-shell">
      <slot />
    </div>

    <script>
      // Spotlight-reveal grid: follow the pointer, "develop" the drafting grid.
      (function () {
        const overlay = document.querySelector<HTMLElement>(".grid-overlay");
        if (!overlay) return;

        const media = window.matchMedia("(pointer: fine)");
        if (!media.matches) return; // touch devices: keep it clean, no reveal

        let raf: number | null = null;
        let x = -400;
        let y = -400;

        function paint() {
          overlay!.style.setProperty("--mx", x + "px");
          overlay!.style.setProperty("--my", y + "px");
          raf = null;
        }

        window.addEventListener(
          "pointermove",
          (event) => {
            x = event.clientX;
            y = event.clientY;
            if (!overlay!.classList.contains("is-live")) {
              overlay!.classList.add("is-live");
            }
            if (raf === null) raf = requestAnimationFrame(paint);
          },
          { passive: true },
        );

        document.addEventListener("pointerleave", () => {
          overlay!.classList.remove("is-live");
        });
      })();
    </script>
  </body>
</html>
