---
import BaseLayout from "../../layouts/base-layout.astro";
import UmbrellaNav from "../../components/umbrella-nav.astro";
import UmbrellaHero from "../../components/umbrella-hero.astro";
import UmbrellaTools from "../../components/umbrella-tools.astro";
import UmbrellaPrinciples from "../../components/umbrella-principles.astro";
import UmbrellaCta from "../../components/umbrella-cta.astro";
import UmbrellaFooter from "../../components/umbrella-footer.astro";
import { locales, defaultLocale, getLocaleFromUrl } from "../../i18n/config";
import { useContent } from "../../i18n/content";

// One static page per non-default locale (en lives at the site root).
export function getStaticPaths() {
  return locales
    .filter((lang) => lang !== defaultLocale)
    .map((lang) => ({ params: { lang } }));
}

const lang = getLocaleFromUrl(Astro.url);
const t = useContent(lang);
---

<BaseLayout
  title={t.meta.umbrellaTitle}
  description={t.meta.umbrellaDescription}
>
  <UmbrellaNav />
  <main>
    <UmbrellaHero />
    <UmbrellaTools />
    <UmbrellaPrinciples />
    <UmbrellaCta />
  </main>
  <UmbrellaFooter />
</BaseLayout>
