---
import BaseLayout from "../layouts/base-layout.astro";
import SiteNav from "../components/site-nav.astro";
import SiteFooter from "../components/site-footer.astro";
import SignupSection from "../components/signup-section.astro";
import { getLocaleFromUrl } from "../i18n/config";
import { useContent } from "../i18n/content";

const lang = getLocaleFromUrl(Astro.url);
const t = useContent(lang);
---

<BaseLayout title={t.signup.metaTitle} description={t.signup.metaDescription}>
  <SiteNav />
  <SignupSection />
  <SiteFooter />
</BaseLayout>
