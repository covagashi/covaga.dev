{
  // Cloudflare Worker configuration for byndr-dev.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "byndr-dev",
  // Production entry re-exports the request handler plus the `GymMcp` Durable
  // Object class. Tests load `src/index.ts` directly (see wrangler.test.jsonc).
  "main": "src/worker.ts",
  "compatibility_date": "2025-07-01",
  // The Agents SDK (MCP Durable Object) relies on Node built-ins (e.g. node:async_hooks).
  "compatibility_flags": ["nodejs_compat"],
  // CORS allow-list for browser clients (the dashboard). "*" echoes any origin;
  // tighten to the dashboard's Pages URL once it is known.
  "vars": { "ALLOWED_ORIGINS": "*" },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "byndr-dev",
      // Run `wrangler d1 create byndr-dev` in your own account and put its id here.
      "database_id": "8199672e-0663-486c-a70b-487d839246a8",
      "migrations_dir": "migrations"
    }
  ],
  // Gym MCP agent, hosted as a Durable Object backed by its own SQLite storage.
  "durable_objects": {
    "bindings": [{ "name": "GYM_MCP", "class_name": "GymMcp" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["GymMcp"] }]
}
